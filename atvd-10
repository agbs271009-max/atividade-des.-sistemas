let numero = parseInt(prompt("Digite um número inteiro positivo para calcular o fatorial:"));

if (isNaN(numero) || numero < 0) {
    alert("Por favor, digite um número inteiro positivo.");
} else {
    let fatorial = 1; 
    let multiplicacao = ""; 

    for (let i = numero; i >= 1; i--) {
        fatorial *= i;
        
        multiplicacao += (i === 1) ? `${i}` : `${i} x `;
    }

    alert(`${numero}! = ${multiplicacao} = ${fatorial}`);
}