let numero = prompt("Digite um número inteiro:");

numero = parseInt(numero);

if (isNaN(numero)) {
    console.log("Isso não parece ser um número válido.");
} else {
    // A mágica acontece aqui: verifica o resto da divisão por 2
    if (numero % 2 === 0) {
        alert(`O número ${numero} é PAR.`);
    } else {
        alert(`O número ${numero} é ÍMPAR.`);
    }
}