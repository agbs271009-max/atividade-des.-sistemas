let limite = parseInt(prompt("Até qual número você deseja contar?"));

if (isNaN(limite) || limite < 1) {
    console.log("Por favor, digite um número inteiro positivo maior que 0.");
} else {
    console.log(`Iniciando contagem até ${limite}:`);

    for (let i = 1; i <= limite; i++) {
        console.log(i);
    }
    
    console.log("Contagem finalizada!");
}